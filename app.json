{
  "expo": {
    "name": "ViaLivre",
    "slug": "ViaLivre",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.projnative.vialivre",
      "versionCode": 1,
      "predictiveBackGestureEnabled": false
    },
    "web": {},
    "plugins": [
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "",
          "iosGoogleMapsApiKey": ""
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3A75AF",
          "image": "src/assets/splashscreen.png",
          "imageWidth": 200
        }
      ]
    ]
  }
}
